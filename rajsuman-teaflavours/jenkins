pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "suman/rajsuman-tea-backend:latest"
        KUBE_NAMESPACE = "devops-demo"
    }

    stages {
        stage('Checkout Code') {
            steps {
                // Pull code from GitHub
                git branch: 'main', url: 'https://github.com/suman15426/raj-suman-tea-flavours.git'
            }
        }

        stage('Build with Maven') {
            steps {
                // Build Java project
                sh 'mvn clean package'
            }
        }

        stage('Unit Tests') {
            steps {
                // Run unit tests
                sh 'mvn test'
            }
        }

        stage('Build Docker Image') {
            steps {
                // Build Docker image
                sh 'docker build -t $DOCKER_IMAGE .'
            }
        }

        stage('Push Docker Image') {
            steps {
                // Push Docker image to Docker Hub
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', 
                                                  passwordVariable: 'DOCKER_PASS', 
                                                  usernameVariable: 'DOCKER_USER')]) {
                    sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                    sh 'docker push $DOCKER_IMAGE'
                }
            }
        }

        stage('Deploy to Kubernetes') {
        steps {
                // Deploy app using Kubernetes YAML files
                sh 'kubectl apply -f k8s/deployment.yaml -n $KUBE_NAMESPACE'
                sh 'kubectl apply -f k8s/service.yaml -n $KUBE_NAMESPACE'
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished!'
        }
    }
}